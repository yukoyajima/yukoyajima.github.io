---
import Layout from '../layouts/Layout.astro';

import HeroSection from '../components/HeroSection.astro';
import AboutSection from '../components/AboutSection.astro';
import UiuxSection from '../components/UiuxSection.astro';
import GraphicsSection from '../components/GraphicsSection.astro';
import IllustrationsSection from '../components/IllustrationsSection.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<HeroSection />
	<AboutSection />
	<UiuxSection />
	<GraphicsSection />
	<IllustrationsSection />
	<Footer />
</Layout>

<style is:global>
	.page-section {
		background: #fff;
		padding: clamp(60px, 12vw, 110px) 3rem clamp(40px, 8vw, 80px);
		position: relative;
		box-sizing: border-box;
		width: 100%;
	}

	.page-section h2 {
		position: absolute;
		top: 0;
		left: 0;
		margin: 0;
		padding: 0;
		font-size: clamp(32px, 8vw, 70px);
		font-weight: 400;
		text-decoration: underline;
		text-underline-offset: clamp(10px, 2vw, 20px);
	}

	.section-gallery {
		display: flex;
		flex-direction: column;
		gap: clamp(20px, 4vw, 45px);
		margin-top: clamp(40px, 8vw, 80px);
	}

	.gallery-row {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		flex-wrap: wrap;
		gap: clamp(20px, 4vw, 45px);
	}

	.gallery-row img {
		height: auto;
		max-width: 100%;
		object-fit: contain;
		object-position: top;
		display: block;
	}

	@media (max-width: 768px) {
		.gallery-row {
			justify-content: center;
		}
	}
</style>
