---
import { Image } from 'astro:assets';

import eyeSvg from '../assets/eye.svg';
import pupilPng from '../assets/pupil.png';
import eyeMaskSvg from '../assets/eye-mask.svg';

const eyeMaskUrl = eyeMaskSvg.src;
---

<main class="eye-stage" aria-label="An illustrated eye whose pupil follows the cursor">
	<p class="corner-welcome">WELCOME2</p>
	<p class="corner-site">YUKOSSITE</p>
	<div class="eye-wrapper">
		<nav class="eye-nav" aria-label="Page sections">
			<a href="#about" class="lash lash-1">ABOUT</a>
			<a href="#uiux" class="lash lash-2">UI/UX</a>
			<a href="#graphics" class="lash lash-3">GRAPHICS</a>
			<a href="#illustrations" class="lash lash-4">ILLUSTRATIONS</a>
		</nav>
		<div class="eye" data-eye>
			<img class="eye-layer eye-art" src={eyeSvg.src} alt="" draggable="false" />
			<div class="pupil-viewport" style={`-webkit-mask-image: url(${eyeMaskUrl}); mask-image: url(${eyeMaskUrl});`}>
				<Image class="pupil" data-pupil src={pupilPng} alt="" draggable="false" />
			</div>
			<div class="movement-bounds" aria-hidden="true"></div>
		</div>
	</div>
</main>

<script>
	const eye = document.querySelector('[data-eye]');
	const pupil = document.querySelector('[data-pupil]');

	if (eye instanceof HTMLElement && pupil instanceof HTMLElement) {
		let lastPointerX = window.innerWidth / 2;
		let lastPointerY = window.innerHeight / 2;
		let updateFrame = 0;
		const visiblePupilInset = 0.48;
		const boundsScaleX = 0.75;
		const boundsScaleY = 0.6;
		const boundsOffsetX = 23;
		const boundsOffsetY = -13;

		const pointPupilAt = (clientX, clientY) => {
			const rect = eye.getBoundingClientRect();
			const centerX = rect.left + window.scrollX + rect.width / 2 + boundsOffsetX;
			const centerY = rect.top + window.scrollY + rect.height / 2 + boundsOffsetY;
			const pageX = clientX + window.scrollX;
			const pageY = clientY + window.scrollY;
			const pupilRect = pupil.getBoundingClientRect();
			const radiusX = Math.max(((rect.width - pupilRect.width * visiblePupilInset) / 2) * boundsScaleX, 0);
			const radiusY = Math.max(((rect.height - pupilRect.height * visiblePupilInset) / 2) * boundsScaleY, 0);
			eye.style.setProperty('--bounds-width', `${radiusX * 2}px`);
			eye.style.setProperty('--bounds-height', `${radiusY * 2}px`);
			eye.style.setProperty('--bounds-center-x', `${boundsOffsetX}px`);
			eye.style.setProperty('--bounds-center-y', `${boundsOffsetY}px`);
			const deltaX = pageX - centerX;
			const deltaY = pageY - centerY;
			const cursorDistance = Math.hypot(deltaX, deltaY);

			if (cursorDistance === 0 || radiusX === 0 || radiusY === 0) {
				centerPupil();
				return;
			}

			const directionX = deltaX / cursorDistance;
			const directionY = deltaY / cursorDistance;
			const trackingRadiusX = window.innerWidth / 2;
			const trackingRadiusY = window.innerHeight / 2;
			const distanceToEyeEdge = 1 / Math.hypot(directionX / radiusX, directionY / radiusY);
			const progress = Math.min(
				Math.hypot(deltaX / trackingRadiusX, deltaY / trackingRadiusY),
				1,
			);
			const pupilX = boundsOffsetX + directionX * distanceToEyeEdge * progress;
			const pupilY = boundsOffsetY + directionY * distanceToEyeEdge * progress;

			pupil.style.setProperty('--pupil-x', `${pupilX}px`);
			pupil.style.setProperty('--pupil-y', `${pupilY}px`);
		};

		const centerPupil = () => {
			pupil.style.setProperty('--pupil-x', `${boundsOffsetX}px`);
			pupil.style.setProperty('--pupil-y', `${boundsOffsetY}px`);
		};

		const schedulePupilUpdate = () => {
			if (updateFrame) return;

			updateFrame = window.requestAnimationFrame(() => {
				updateFrame = 0;
				pointPupilAt(lastPointerX, lastPointerY);
			});
		};

		window.addEventListener('pointermove', (event) => {
			lastPointerX = event.clientX;
			lastPointerY = event.clientY;
			pointPupilAt(lastPointerX, lastPointerY);
		});
		window.addEventListener('scroll', schedulePupilUpdate, { passive: true });
		window.addEventListener('resize', schedulePupilUpdate);
		window.addEventListener('pointerleave', centerPupil);
		window.addEventListener('blur', centerPupil);
		schedulePupilUpdate();
	}

</script>

<style>
	.corner-welcome {
		position: absolute;
		top: 0;
		left: 0;
		margin: 0;
		padding: 0;
		font-size: clamp(40px, 8vw, 70px);
		font-weight: 400;
		line-height: 0.9;
		z-index: 10;
		color: #111;
	}

	.corner-site {
		position: absolute;
		bottom: 0;
		right: 0;
		margin: 0;
		padding: 0;
		font-size: clamp(54px, 10vw, 100px);
		font-weight: 400;
		line-height: 0.85;
		z-index: 10;
		color: #111;
	}

	.eye-stage {
		position: relative;
		min-height: 100svh;
		display: grid;
		place-items: center;
		background: #38FFFB;
	}

	.eye-wrapper {
		position: relative;
	}

	.eye-nav {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 10;
	}

	.lash {
		position: absolute;
		transform-origin: bottom left;
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-underline-offset: 5px;
		color: #111;
		white-space: nowrap;
		pointer-events: auto;
		font-size: clamp(14px, 3.5vw, 30px);
		font-weight: 400;
		line-height: 1;
	}

	.lash-1 {
		left: 56%;
		bottom: 88.5%;
		transform: rotate(-49.16deg);
	}

	.lash-2 {
		left: 71%;
		bottom: 85%;
		transform: rotate(-48.79deg);
	}

	.lash-3 {
		left: 85%;
		bottom: 72%;
		transform: rotate(-49.32deg);
	}

	.lash-4 {
		left: 99%;
		bottom: 57%;
		transform: rotate(-45.12deg);
	}

	.eye {
		--mask-x: 17px;
		--mask-y: 2.5px;
		position: relative;
		width: min(72vw, 596px);
		aspect-ratio: 699 / 451;
		overflow: hidden;
	}

	.eye-layer,
	.pupil-viewport,
	.movement-bounds,
	.pupil {
		user-select: none;
		pointer-events: none;
	}

	.eye-layer {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: fill;
	}

	.eye-art {
		z-index: 1;
	}

	.pupil-viewport {
		position: absolute;
		z-index: 2;
		inset: 0;
		overflow: hidden;
		overflow: clip;
		-webkit-mask-repeat: no-repeat;
		mask-repeat: no-repeat;
		-webkit-mask-position: calc(50% + var(--mask-x)) calc(50% + var(--mask-y));
		mask-position: calc(50% + var(--mask-x)) calc(50% + var(--mask-y));
		-webkit-mask-size: 100% 100%;
		mask-size: 100% 100%;
	}

	.pupil {
		--pupil-x: 0px;
		--pupil-y: 0px;
		position: absolute;
		left: 50%;
		top: 50%;
		width: 70%;
		height: auto;
		transform: translate(calc(-50% + var(--pupil-x)), calc(-50% + var(--pupil-y)));
	}

	@media (max-width: 760px) {
		.eye-stage {
			overflow-x: clip;
		}

		.eye-wrapper {
			transform: translateX(-12vw);
		}
	}
</style>
